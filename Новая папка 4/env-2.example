# Скопируйте этот файл в .env и заполните реальными значениями.
# .env НИКОГДА не должен попадать в git / фронтенд / клиентский код.

# Токен бота из @BotFather. ОБЯЗАТЕЛЬНО новый, перевыпущенный через /revoke_token —
# старый токен, который был показан в чате, считается скомпрометированным.
BOT_TOKEN=123456789:PUT_YOUR_NEW_TOKEN_HERE

# Секрет для проверки, что вебхук действительно шлёт Telegram (Bot API secret_token)
# Сгенерируйте случайную строку, например: openssl rand -hex 32
WEBHOOK_SECRET=change_me_to_a_random_string

# Публичный HTTPS-адрес вашего бэкенда (нужен, чтобы зарегистрировать webhook)
PUBLIC_URL=https://your-backend-domain.example.com

# Порт, на котором слушает сервер
PORT=3000

# Telegram ID единственного аккаунта, которому доступна админ-панель в игре.
# Узнать свой ID: напишите любое сообщение боту @userinfobot — он ответит вашим ID.
# Это должно быть число, например 123456789 (без @ и без кавычек).
# Если оставить пустым — админ-панель будет недоступна вообще никому.
ADMIN_TELEGRAM_ID=
